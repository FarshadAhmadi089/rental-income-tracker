# Rental Tracker - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NOTE: This is for documentation only - environment variables are not currently used in the app

# API Configuration
# The API base URL is currently hardcoded in src/services/api.ts
# To use environment variables with Expo, you would need to:
# 1. Install expo-constants: npm install expo-constants
# 2. Add to app.json under "expo.extra"
# 3. Access via Constants.expoConfig.extra in your code
API_BASE_URL=https://api.takamul-cars.com

# Backend Environment Variables (for FastAPI server)
# These would be configured on the DigitalOcean droplet, not in this frontend app

# Database
# DATABASE_URL=sqlite:///./rental_tracker.db

# JWT Secret (generated with: openssl rand -hex 32)
# JWT_SECRET_KEY=your-secret-key-here

# Email Service (Resend API)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SSL/TLS Configuration
# CERT_PATH=/etc/letsencrypt/live/api.takamul-cars.com/fullchain.pem
# KEY_PATH=/etc/letsencrypt/live/api.takamul-cars.com/privkey.pem
